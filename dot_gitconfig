###
# GITCONFIG CONFIGURATION FILE
###

###
# CONFIGURES THE CORE SECTION
###
[core]
	editor = vim

###
# CONFIGURES THE CREDENTIAL SECTION
###
[credential]
	helper = cache

###
# CONFIGURES THE INIT SECTION
###
[init]
	defaultBranch = main

###
# CONFIGURES THE PUSH SECTION
###
[push]
  default = simple

###
# CONFIGURES THE USER SECTION
###
